{
    "version": "0.2.0",
    "configurations": [
        {
            "name": ".NET Core Attach (Pick Process)",
            "type": "coreclr",
            "request": "attach",
            "processId": "${command:pickProcess}",
            "preLaunchTask": "build"
        },
        {
            "name": ".NET Core Attach (pwsh.exe)",
            "type": "coreclr",
            "request": "attach",
            "processName": "pwsh.exe",
            "preLaunchTask": "build"
        }
    ]
}